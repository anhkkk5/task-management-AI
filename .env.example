# ===== Core =====
NODE_ENV=development
PORT=3002
MONGO_URL=mongodb://localhost:27017/ai_task_management

# ===== Frontend origins (for CORS + socket) =====
CLIENT_URL=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# ===== JWT =====
JWT_SECRET=change-me-in-local
JWT_ACCESS_SECRET=change-me-in-local
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_SECRET=change-me-in-local
JWT_REFRESH_EXPIRES_IN=1d
JWT_REFRESH_TTL_SECONDS=86400
# Optional backward-compat key
REFRESH_TOKEN_TTL_SECONDS=86400

# ===== Redis (required by queue / realtime worker) =====
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_TLS=false

# ===== Google OAuth (optional in local, required if testing Google login) =====
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3002/auth/google/callback

# ===== Mail (optional in local unless testing email) =====
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@taskmanagement.local
EMAIL_FROM_NAME=TaskMind Local
SMTP_FROM=

# ===== Cloudinary (optional unless testing upload/chat media) =====
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ===== AI providers (optional unless testing AI features) =====
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.1-8b-instant

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ===== Optional tuning =====
BCRYPT_SALT_ROUNDS=10
AI_ERA_KNOWLEDGE_FACTOR=0.6
